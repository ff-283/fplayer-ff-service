{
  "name": "fplayer-ff-service-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Simple control panel for fplayer ff service",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack:dir": "electron-builder --dir",
    "dist:win": "electron-builder --win portable",
    "dist:linux": "electron-builder --linux AppImage --x64"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.fplayer.ffservice",
    "productName": "FPlayerFFService",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../3rd",
        "to": "3rd"
      },
      {
        "from": "../scripts",
        "to": "scripts"
      },
      {
        "from": "../gateway/bin",
        "to": "gateway/bin"
      },
      {
        "from": "../kernel-console/bin",
        "to": "kernel-console/bin"
      },
      {
        "from": "../doc/img",
        "to": "doc/img"
      }
    ],
    "win": {
      "icon": "../doc/img/icon.png",
      "target": [
        "portable"
      ]
    },
    "linux": {
      "category": "AudioVideo",
      "target": [
        "AppImage"
      ]
    }
  }
}
